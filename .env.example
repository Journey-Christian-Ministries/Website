# Journey Christian Ministries — required environment variables (names only).
# Populate the real values in Vercel Project Settings → Environment Variables.
# Do NOT commit real values. These are read server-side (see README).

# Cloudflare Turnstile site key (public). Read server-side and passed to the
# client form as a prop. Intentionally NOT prefixed with NEXT_PUBLIC_.
TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key (server only — never exposed to the client).
TURNSTILE_SECRET_KEY=

# Resend API key for contact-form email delivery (server only).
RESEND_API_KEY=
